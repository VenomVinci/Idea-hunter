{
  "manifest_version": 3,
  "name": "Hunter - YouTube Tutorial Assistant",
  "version": "1.0.0",
  "description": "Enhances YouTube tutorial videos with AI-powered topics, summaries, and quizzes.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://www.youtube.com/*",
    "http://www.youtube.com/*"
  ],
  "options_page": "options/options.html",
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "http://www.youtube.com/*"
      ],
      "js": ["contentScript.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Hunter"
  }
}